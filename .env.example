# LeoBook Environment Configuration
# =================================

# --- SYSTEM SETTINGS ---
LEO_CYCLE_WAIT_HOURS=6
HEADLESS_MODE=False

# --- DATABASE (SUPABASE) ---

# --- FOOTBALL.COM CREDENTIALS ---
FB_PHONE=your_football.com_phone_number
FB_PASSWORD=your_football.com_password

# --- AI INTELLIGENCE ---
# xAI Grok API Key (optional — Gemini is primary)
GROK_API_KEY=your_grok_api_key
# Google Gemini API Keys (comma-separated, 25+ keys for free-tier rotation)
GEMINI_API_KEY=key1,key2,key3,...,key25

# --- DATABASE (SUPABASE) ---
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to GitHub!

# Your Supabase project URL (from Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role Key for admin operations (from Project Settings → API → Service Role Key)
# Keep this SECRET! Only use on backend/scripts, never in Flutter app!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anon/Public Key for Flutter app (safe to expose in client apps)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- CONCURRENCY ---
MAX_CONCURRENCY=4

# --- ANDROID RELEASE APK (Leo.py --deploy-apk / infra/deploy_apk.sh) ---
# Script loads leobookapp/.env then infra/.env. Required unless android/key.properties already exists.
# Keystore: path to .jks on disk, OR base64 of the keystore file (for CI/Codespaces).
# LEOBOOK_KEYSTORE_PATH=/absolute/or/repo-relative/path/to/upload-keystore.jks
# LEOBOOK_KEYSTORE_BASE64=
LEOBOOK_STORE_PASSWORD=
LEOBOOK_KEY_ALIAS=
LEOBOOK_KEY_PASSWORD=
# Upload uses service role (same as SUPABASE_SERVICE_KEY if named that way):
# SUPABASE_SERVICE_ROLE_KEY=...   (or SUPABASE_SERVICE_KEY above)
